# RentMasseur automation credentials (used by optimizer / availability keeper)
RENTMASSEUR_USERNAME=your_username
RENTMASSEUR_PASSWORD=your_password

# Groq API key for bio generation and intent routing
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# Clickable booking link used in bios and CTAs
REBRANDLY_LINK=https://rebrand.ly/your-booking-link

# Hugging Face Space for deployment
HF_SPACE_NAME=your-username/rentmasseur-optimizer
